        VARS["CSS Custom Properties<br/>--background, --foreground<br/>--primary, --secondary<br/>--accent, --muted, --border<br/>--card, --popover, --ring<br/>--destructive"]
    end

    subgraph Tailwind["tailwind.config.js"]
